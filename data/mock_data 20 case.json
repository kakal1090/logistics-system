/**
 * Gửi toàn bộ 20 đơn lên server qua socket.
 * Gọi hàm này sau khi socket đã kết nối.
 */
function sendMockOrders(socket, delayMs = 300) {
  console.log(`[Mock] Gửi ${MOCK_ORDERS.length} đơn hàng mẫu...`);
  MOCK_ORDERS.forEach((order, i) => {
    setTimeout(() => {
      const payload = { ...order };
      delete payload.expected_label;
      delete payload.expected_vehicle;
      socket.emit("submit_order", payload);
      console.log(`[Mock] Gửi ${order.order_id}`);
    }, i * delayMs);
  });
}
 
// Nếu dùng trong môi trường Node (test script)
if (typeof module !== "undefined") {
  module.exports = { MOCK_ORDERS, sendMockOrders };
}
 
